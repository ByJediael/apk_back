# Exemplo: publicar a API no mesmo domínio do n8n
# O APK usa base URL: https://n8n.jediael.uk/webhook
# Requisições: https://n8n.jediael.uk/webhook/api/v1/health
#
# Ajuste o upstream para onde o backup-api roda (localhost:8080).

location /webhook/api/ {
    client_max_body_size 500M;
    proxy_pass http://127.0.0.1:8080/api/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}
